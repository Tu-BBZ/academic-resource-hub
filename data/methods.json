      ],
      "tools": [
        "Python (matplotlib/seaborn)",
        "R (ggplot2)",
        "Excel"
      ]
    },
    {
      "name": "探索性数据分析（EDA）",
      "category": "描述统计",
      "description": "通过可视化（散点图、箱线图、热力图等）和基本统计手段初步了解数据特征、发现异常值、检测变量关系。是正式建模前必不可少的步骤。",
