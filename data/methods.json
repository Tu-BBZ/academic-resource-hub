        }
      ],
      "tools": [
        "Python (statsmodels/sklearn)",
        "R (lm)",
        "SPSS",
        "Stata"
      ]
    },
    {
      "name": "逻辑回归（Logistic Regression）",
      "category": "回归分析",
      "description": "用于因变量为二分类或多分类的情境，如土地是否发生转化、居民是否选择迁居等。通过Logit变换将线性模型的输出映射到概率空间。",
      "links": [
        {
